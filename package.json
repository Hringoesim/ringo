{
  "name": "ringo-esim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Ringo — one plan, every country. Identity-led eSIM travel app (iPhone prototype, ported to Vite + React + TS).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "ios:add": "cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "sync": "npm run build && cap sync"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@supabase/supabase-js": "^2.108.2",
    "d3-geo": "^3.1.1",
    "qrcode-generator": "^2.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@eslint/js": "^9.39.4",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.11"
  }
}
