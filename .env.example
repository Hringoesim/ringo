# Ringo — environment configuration.
# Copy to `.env` (or `.env.local`) and fill in. All client vars must be VITE_*.
# The app runs fully on the bundled mock backend with NONE of these set.

# ── Backend mode ──────────────────────────────────────────────────────────────
# 'mock' (default, in-memory) | 'live' (real orchestration API)
VITE_RINGO_API_MODE=mock
# Base URL of the live orchestration API (used when mode = live)
VITE_RINGO_API_BASE_URL=https://api.ringoesim.com/v1

# ── Auth ──────────────────────────────────────────────────────────────────────
# Google OAuth client ID → enables real Google Identity Services sign-in.
# Create at https://console.cloud.google.com → Credentials → OAuth client (Web).
# Add your origin (e.g. https://hringoesim.github.io) to Authorized JS origins.
VITE_GOOGLE_CLIENT_ID=
# Optional custom auth backend base URL.
VITE_AUTH_BACKEND=

# ── Supabase (optional backend: Postgres + Auth + Storage) ────────────────────
# Create a project at https://supabase.com, run supabase/schema.sql, then paste:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Social sign-in (Apple/Google) via Supabase Auth. Comma-separated allow-list of
# providers whose OAuth credentials you've configured in Supabase → Auth →
# Providers. Buttons for providers NOT listed show a friendly "not connected yet"
# message instead of redirecting to an error. e.g. VITE_OAUTH_PROVIDERS=google,apple
VITE_OAUTH_PROVIDERS=

# ── Wholesale partners (routing hints; integrations live server-side) ─────────
VITE_PARTNER_MNP=1global
VITE_PARTNER_RSP=
VITE_PARTNER_VOICE=telnyx
VITE_PARTNER_IDENTITY=onfido
